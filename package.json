{
  "name": "@gonkagate/kilo-setup",
  "version": "0.2.1",
  "description": "Setup CLI for configuring local Kilo to use GonkaGate.",
  "type": "module",
  "bin": {
    "kilo-setup": "bin/gonkagate-kilo.js",
    "gonkagate-kilo": "bin/gonkagate-kilo.js"
  },
  "files": [
    "bin",
    "dist",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json",
    "test": "npm run build && node scripts/run-tests.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "package:check": "publint",
    "ci": "npm run typecheck && npm run test && npm run format:check && npm run package:check",
    "prepack": "npm run ci"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "keywords": [
    "gonkagate",
    "kilo",
    "kilocode",
    "installer",
    "cli",
    "custom provider",
    "openai compatible"
  ],
  "license": "Apache-2.0",
  "homepage": "https://github.com/GonkaGate/kilo-setup#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GonkaGate/kilo-setup.git"
  },
  "bugs": {
    "url": "https://github.com/GonkaGate/kilo-setup/issues"
  },
  "packageManager": "npm@11.11.1",
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "commander": "^14.0.3",
    "jsonc-parser": "^3.3.1",
    "semver": "^7.7.3",
    "write-file-atomic": "^7.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.1",
    "@types/semver": "^7.7.1",
    "@types/write-file-atomic": "^4.0.3",
    "prettier": "^3.6.2",
    "publint": "^0.3.15",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
